<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/pages/shared.css" />
    <title>Log In</title>
    <script type="module" src="/pages/login/main.js" defer></script>
  </head>
  <body>
    <div id="root">
      <%- include("partials/header.ejs", { title: "log in"}) %>
      <main>
        <% if (errors && errors.length > 0) { %>
        <span
          class="flash-error block bg-red-50 text-red-600 border border-red-200 p-3 rounded-lg font-medium text-xs mb-4 w-max"
        >
          <%= errors[0] %>
        </span>
        <% } %>
        <header>
          <div>
            <img src="/images/anon-logo.png" alt="" />
          </div>
          <h2>welcome back!</h2>
        </header>
        <span data-error="network" class="hidden"></span>
        <form action="/login" method="post">
          <div>
            <span data-error="email" class="hidden"></span>
            <label for="email">email address:</label>
            <input
              type="email"
              name="email"
              id="email"
              autocomplete="email"
              placeholder="example@domain.com"
            />
          </div>
          <div>
            <span data-error="password" class="hidden"></span>
            <label for="password">password:</label>
            <input
              type="password"
              name="password"
              id="password"
              autocomplete="current-password"
              placeholder="****************"
            />
          </div>
          <button type="submit" id="submit">log in</button>
        </form>
        <div>
          <span>new here?</span>
          <a href="/register">register</a>
        </div>
      </main>
    </div>
  </body>
</html>
