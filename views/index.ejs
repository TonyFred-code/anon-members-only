        <ul>
          <li><a href="/login">log in</a></li>
          <li><a href="/register">register</a></li>
          <li><a href="/guest">guest</a></li>
        </ul>
        <div>
          <hr />
          <span>or</span>
          <hr />
        </div>
        <section>
          <h2>demo accounts</h2>
          <ul>
            <li><a href="/demo/admin">admin</a></li>
            <li><a href="/demo/member">member</a></li>
          </ul>
        </section>
      </main>
    </div>
  </body>
</html>
